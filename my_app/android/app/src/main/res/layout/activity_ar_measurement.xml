<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ARCore camera background renders into this GLSurfaceView. -->
    <android.opengl.GLSurfaceView
        android:id="@+id/ar_surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Crosshair in the screen center to help workers aim. -->
    <View
        android:id="@+id/ar_crosshair"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="center"
        android:background="@drawable/ar_crosshair"/>

    <!-- Top instruction strip. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top"
        android:background="#CC101724"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/ar_cancel_button"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Close"
                android:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/ar_step_indicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Step 1 of 2 — WIDTH"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/ar_tracking_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#FFC107"
                android:textSize="22sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/ar_instruction_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Move phone slowly to scan surface. Then tap on FIRST corner of window."
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/ar_distance_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAlignment="center"
            android:textColor="#FFD54F"
            android:textSize="26sp"
            android:textStyle="bold"
            android:text=""/>
    </LinearLayout>

    <!-- Bottom action bar. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="#CC101724"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <TextView
            android:id="@+id/ar_saved_measurements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"
            android:text=""/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/ar_reset_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Reset"
                android:textAllCaps="false"
                android:backgroundTint="#37475A"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/ar_capture_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.4"
                android:layout_marginHorizontal="6dp"
                android:text="Save Width"
                android:textAllCaps="false"
                android:backgroundTint="#2E7BE0"
                android:textColor="#FFFFFF"
                android:enabled="false"/>

            <Button
                android:id="@+id/ar_confirm_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Done"
                android:textAllCaps="false"
                android:backgroundTint="#1B8C57"
                android:textColor="#FFFFFF"
                android:enabled="false"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
